# adkit configuration. Copy this file to .env and fill in your own values.
# .env is gitignored and must never be committed. These are placeholders only.

# --- Meta / Facebook Graph API (required) ---
# A long-lived user or system-user access token with ads_management, ads_read,
# pages_manage_ads, pages_read_engagement, instagram_basic, and
# instagram_content_publish. See docs/setup-token.md.
META_ACCESS_TOKEN=REPLACE_WITH_YOUR_TOKEN

# Your Meta app credentials (used to extend/refresh tokens).
META_APP_ID=REPLACE_WITH_YOUR_APP_ID
META_APP_SECRET=REPLACE_WITH_YOUR_APP_SECRET

# The ad account to manage. Bare id or act_ prefixed; adkit normalizes it.
META_AD_ACCOUNT_ID=act_REPLACE_WITH_YOUR_AD_ACCOUNT_ID

# The Facebook Page behind your ads, and its linked Instagram account.
META_PAGE_ID=REPLACE_WITH_YOUR_PAGE_ID
META_INSTAGRAM_ACTOR_ID=REPLACE_WITH_YOUR_IG_ACCOUNT_ID

# Graph API version to target.
META_API_VERSION=v21.0

# Default destination URL for website creatives when an ad omits `link`.
ADVERTISER_URL=https://your-site.com

# --- AI creative generation (optional: only for `adkit generate` / brief generate blocks) ---
# Google AI Studio key for Gemini image and Veo video generation.
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY

# Where the gemskills toolkit is cloned, and where generated files are written.
# Defaults: ~/dev/gemskills and ./creatives
# GEMSKILLS_ROOT=/absolute/path/to/gemskills
# ADKIT_CREATIVE_DIR=/absolute/path/to/creatives
# BUN=/absolute/path/to/bun
